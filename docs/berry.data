<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Try Berry On Browser</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>
  <div id="terminal"></div>
</body>

<script defer src="term.js"></script>
<script defer src="repl.js"></script>
<script async src="berry.js"></script>

