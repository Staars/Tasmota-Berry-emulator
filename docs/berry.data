                <input type="range" id="matrix_w" name="matrix_w" min="1" max="64" list="pixel_width" onchange="led_strip.w = this.value;"></input>
                <label for="matrix_w">32</label>
                <datalist id="pixel_width">
                    <select></select>
                    <option value="1"></option>
