# painter superclass
class Animate_painter

  def init()
    # register ourselves into the current animate.core
    var core = global._cur_anim
    if (core != nil)
      core.add_painter(self)
    end
  end

  # return true if buffer was filled successfully
  #
  # Needs to be overwritten
  def paint(frame)
  end

end
