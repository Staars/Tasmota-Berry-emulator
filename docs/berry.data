var crypto = {}

# generate n random bytes as a bytes object
crypto.random = def(n)
  import math
  var b = bytes(n)
  for i : 0 .. n - 1
    b[i] = math.rand() & 0xFF
  end
  return b
end

return crypto
#################################################################################
# dyn class
#
# Allows to use a map with members
# see https://github.com/berry-lang/berry/wiki/Chapter-8
#################################################################################
#@ solidify:dyn
class dyn
  var _attr
  def init()
      self._attr = {}
  end
  def setmember(name, value)
      self._attr[name] = value
  end
  def member(name)
    if self._attr.contains(name)
        return self._attr[name]
    else
        import undefined
        return undefined
    end
  end
  def tostring()
    return self._attr.tostring()
  end
end#!/usr/bin/env -S ../../../lib/libesp32/berry/berry -s -g
